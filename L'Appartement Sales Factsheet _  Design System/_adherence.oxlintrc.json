{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "ui_kits/presentation/**",
              "ui_kits/presentation/components/**",
              "ui_kits/presentation/data/**",
              "ui_kits/presentation/pages/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Inter|Ivy Mode))/i]",
        "message": "Font not provided by the design system. Available: Inter, Ivy Mode."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
  "x-omelette": {
    "components": {},
    "tokens": [
      "--accent-color",
      "--accent-text-color",
      "--color-bg",
      "--color-cover-fallback",
      "--color-fg",
      "--color-fg-caption",
      "--color-fg-soft",
      "--font-body",
      "--font-display",
      "--font-ornament",
      "--fw-bold",
      "--fw-light",
      "--fw-medium",
      "--fw-regular",
      "--fw-semibold",
      "--inset-name",
      "--inset-text",
      "--la-beige",
      "--la-black",
      "--la-cover-fb",
      "--la-grey-caption",
      "--la-white",
      "--lh-body",
      "--lh-detail",
      "--lh-fiche",
      "--lh-italic-cap",
      "--lh-name",
      "--lh-note",
      "--lh-quote",
      "--lh-quote-mark",
      "--lh-tight",
      "--page-h",
      "--page-margin",
      "--page-margin-l",
      "--page-w",
      "--quote-bg",
      "--quote-fg",
      "--t-bio",
      "--t-bio-name",
      "--t-closeup-cap",
